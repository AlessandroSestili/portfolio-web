---
const links = [
  { href: '#about',    label: 'About'    },
  { href: '#stack',    label: 'Stack'    },
  { href: '#projects', label: 'Progetti' },
  { href: '#contact',  label: 'Contatti' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">

    <!-- Logo mark -->
    <a href="#" class="group flex items-center gap-3">
      <div
        class="w-10 h-10 rounded-xl flex items-center justify-center text-sm font-bold font-mono text-white
               transition-all duration-300 group-hover:scale-110 group-hover:rotate-3"
        style="background:linear-gradient(135deg,#7C3AED,#06B6D4);box-shadow:0 0 20px rgba(124,58,237,0.45);"
      >
        AS
      </div>
      <span class="hidden sm:block font-mono text-xs text-white/40 group-hover:text-white/70 transition-colors">
        alessandrosestili.dev
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class="relative text-sm font-medium text-white/50 hover:text-white transition-colors duration-200 group"
          >
            {l.label}
            <span class="absolute -bottom-0.5 left-0 h-px w-0 bg-gradient-to-r from-violet-500 to-cyan-400
                         transition-all duration-300 group-hover:w-full"></span>
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <div class="hidden md:flex items-center gap-3">
      <a href="#contact" class="btn-primary text-sm py-2 px-5">
        Hire me
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button id="hamburger" class="md:hidden p-2 text-white/50 hover:text-white transition-colors" aria-label="Menu">
      <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden glass border-t border-white/5">
    <ul class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-4">
      {links.map((l) => (
        <li>
          <a href={l.href} class="block text-sm font-medium text-white/60 hover:text-white transition-colors mobile-link">
            {l.label}
          </a>
        </li>
      ))}
      <li>
        <a href="#contact" class="btn-primary text-sm py-2 px-5 w-fit">Hire me</a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const navbar   = document.getElementById('navbar');
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen   = document.getElementById('icon-open');
  const iconClose  = document.getElementById('icon-close');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  });

  hamburger?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });

  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });
</script>
