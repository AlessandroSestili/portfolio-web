---
type Project = {
  id: number;
  title: string;
  subtitle: string;
  description: string;
  tags: string[];
  accentColor: string;
  glowColor: string;
  status: 'Live' | 'WIP' | 'Open Source';
  featured: boolean;
  demoUrl?: string;
  codeUrl?: string;
  mockupStyle: string;
};

const projects: Project[] = [
  {
    id: 1,
    title: 'UI Playground',
    subtitle: 'Interactive component library',
    description:
      'Una libreria interattiva di componenti UI e animazioni avanzate. Ogni componente è costruito con attenzione maniacale ai dettagli: micro-interazioni, transizioni fluide e pattern CSS creativi. Un campo di gioco per esplorare i limiti del web moderno.',
    tags: ['React', 'TypeScript', 'CSS Animations', 'Tailwind CSS', 'Framer Motion'],
    accentColor: '#7C3AED',
    glowColor: 'rgba(124,58,237,0.35)',
    status: 'Live',
    featured: true,
    demoUrl: '#',
    codeUrl: '#',
    mockupStyle:
      'background:linear-gradient(135deg,rgba(124,58,237,0.2) 0%,rgba(6,182,212,0.1) 100%)',
  },
  {
    id: 2,
    title: 'Dashboard Analytics',
    subtitle: 'Real-time data visualization',
    description:
      'Dashboard enterprise con grafici real-time, filtri avanzati e reportistica dinamica. Costruita con Angular e RxJS per gestire stream di dati ad alta frequenza.',
    tags: ['Angular', 'TypeScript', 'RxJS', 'D3.js', 'NgRx'],
    accentColor: '#06B6D4',
    glowColor: 'rgba(6,182,212,0.3)',
    status: 'WIP',
    featured: false,
    demoUrl: '#',
    codeUrl: '#',
    mockupStyle:
      'background:linear-gradient(135deg,rgba(6,182,212,0.2) 0%,rgba(245,158,11,0.08) 100%)',
  },
  {
    id: 3,
    title: 'Vue Design System',
    subtitle: 'Scalable component library',
    description:
      'Design system scalabile con oltre 50 componenti documentati, varianti tematiche e integrazione Storybook. Pubblicato come pacchetto npm.',
    tags: ['Vue 3', 'TypeScript', 'Storybook', 'SCSS', 'Vite'],
    accentColor: '#F59E0B',
    glowColor: 'rgba(245,158,11,0.3)',
    status: 'Open Source',
    featured: false,
    demoUrl: '#',
    codeUrl: '#',
    mockupStyle:
      'background:linear-gradient(135deg,rgba(245,158,11,0.2) 0%,rgba(124,58,237,0.08) 100%)',
  },
];

const statusColors: Record<string, string> = {
  'Live': 'bg-emerald-400/15 text-emerald-400 border-emerald-400/30',
  'WIP': 'bg-amber-400/15 text-amber-400 border-amber-400/30',
  'Open Source': 'bg-cyan-400/15 text-cyan-400 border-cyan-400/30',
};
---

<section id="projects" class="relative py-32 px-6 overflow-hidden">
  <!-- Separator -->
  <div class="max-w-6xl mx-auto mb-16">
    <div class="h-px w-full" style="background:linear-gradient(to right,transparent,rgba(6,182,212,0.4),transparent);"></div>
  </div>

  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="reveal text-center mb-16">
      <span class="section-badge mb-4 inline-flex">// selected_works</span>
      <h2 class="text-4xl sm:text-5xl font-black text-white mt-4">
        Progetti <span class="text-gradient">selezionati</span>
      </h2>
      <p class="text-white/40 mt-4 max-w-xl mx-auto text-sm">
        Una selezione dei lavori più significativi — ogni progetto racconta una storia diversa.
      </p>
    </div>

    <!-- Projects layout -->
    <div class="space-y-8">

      {/* ── Featured project (full-width) ── */}
      {projects.filter(p => p.featured).map(p => (
        <div class="reveal card-tilt">
          <div
            class="gradient-border rounded-2xl overflow-hidden"
            style={`--accent:${p.accentColor};`}
          >
            <div class="grid lg:grid-cols-2 gap-0 min-h-[420px]">

              <!-- Mockup panel -->
              <div
                class="relative flex items-center justify-center p-10 min-h-[260px] lg:min-h-auto"
                style={p.mockupStyle}
              >
                <!-- Browser mockup -->
                <div class="w-full max-w-sm glass rounded-xl overflow-hidden shadow-2xl"
                     style={`box-shadow: 0 20px 60px ${p.glowColor};`}>
                  <div class="px-3 py-2 flex items-center gap-1.5 border-b border-white/5"
                       style="background:rgba(255,255,255,0.03);">
                    <span class="w-2.5 h-2.5 rounded-full bg-red-400/70"></span>
                    <span class="w-2.5 h-2.5 rounded-full bg-yellow-400/70"></span>
                    <span class="w-2.5 h-2.5 rounded-full bg-green-400/70"></span>
                    <span class="flex-1 ml-2 h-4 rounded bg-white/5 text-[9px] font-mono text-white/25 flex items-center px-2">
                      ui-playground.dev
                    </span>
                  </div>
                  <div class="p-4 space-y-3">
                    <div class="flex gap-2">
                      <div class="h-8 w-16 rounded-lg" style={`background:${p.accentColor}40;border:1px solid ${p.accentColor}50;`}></div>
                      <div class="h-8 flex-1 rounded-lg bg-white/5"></div>
                    </div>
                    <div class="grid grid-cols-3 gap-2">
                      {[p.accentColor, '#06B6D4', '#F59E0B'].map(c => (
                        <div class="h-16 rounded-lg animate-pulse-slow"
                             style={`background:${c}20;border:1px solid ${c}30;`}></div>
                      ))}
                    </div>
                    <div class="space-y-1.5">
                      {[70, 90, 55].map(w => (
                        <div class="h-2 rounded-full bg-white/5" style={`width:${w}%`}></div>
                      ))}
                    </div>
                  </div>
                </div>
              </div>

              <!-- Info panel -->
              <div class="flex flex-col justify-center p-8 lg:p-12">
                <div class="flex items-center gap-3 mb-4">
                  <span class={`text-xs font-mono font-semibold px-2.5 py-1 rounded-full border ${statusColors[p.status]}`}>
                    {p.status === 'Live' && '● '}
                    {p.status}
                  </span>
                  <span class="text-xs text-white/25 font-mono">Featured</span>
                </div>

                <h3 class="text-3xl sm:text-4xl font-black text-white mb-2">{p.title}</h3>
                <p class="font-mono text-sm mb-4" style={`color:${p.accentColor};`}>{p.subtitle}</p>

                <p class="text-white/55 text-sm leading-relaxed mb-6">{p.description}</p>

                <!-- Tags -->
                <div class="flex flex-wrap gap-2 mb-8">
                  {p.tags.map(tag => (
                    <span class="text-xs font-mono px-2.5 py-1 rounded-full glass" style={`border-color:${p.accentColor}30;color:${p.accentColor}cc;`}>
                      {tag}
                    </span>
                  ))}
                </div>

                <!-- Links -->
                <div class="flex gap-3">
                  <a href={p.demoUrl} class="btn-primary text-sm py-2.5 px-5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                    </svg>
                    Live Demo
                  </a>
                  <a href={p.codeUrl} class="btn-secondary text-sm py-2.5 px-5">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                    </svg>
                    Codice
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}

      {/* ── Other projects (2-col grid) ── */}
      <div class="grid sm:grid-cols-2 gap-8">
        {projects.filter(p => !p.featured).map((p, i) => (
          <div class={`reveal reveal-delay-${i + 2} card-tilt`}>
            <div
              class="glass glass-hover rounded-2xl overflow-hidden h-full flex flex-col"
              style={`border-color:${p.accentColor}20;`}
            >
              <!-- Mockup thumbnail -->
              <div
                class="h-44 relative flex items-center justify-center p-6"
                style={p.mockupStyle}
              >
                <div class="grid grid-cols-3 gap-2 w-full max-w-[200px]">
                  {[p.accentColor, '#fff', '#06B6D4'].map(c => (
                    <div class="h-10 rounded-lg animate-pulse-slow"
                         style={`background:${c}25;border:1px solid ${c}30;`}></div>
                  ))}
                  <div class="h-10 col-span-2 rounded-lg animate-pulse-slow"
                       style={`background:${p.accentColor}15;border:1px solid ${p.accentColor}25;`}></div>
                  <div class="h-10 rounded-lg" style={`background:rgba(255,255,255,0.04);`}></div>
                </div>
              </div>

              <!-- Content -->
              <div class="flex flex-col flex-1 p-6">
                <div class="flex items-center justify-between mb-3">
                  <span class={`text-xs font-mono font-semibold px-2 py-0.5 rounded-full border ${statusColors[p.status]}`}>
                    {p.status}
                  </span>
                  <span class="font-mono text-xs" style={`color:${p.accentColor};`}>{p.subtitle}</span>
                </div>

                <h3 class="text-xl font-bold text-white mb-2">{p.title}</h3>
                <p class="text-white/50 text-sm leading-relaxed mb-4 flex-1">{p.description}</p>

                <div class="flex flex-wrap gap-1.5 mb-5">
                  {p.tags.slice(0, 4).map(tag => (
                    <span class="text-[10px] font-mono px-2 py-0.5 rounded-full"
                          style={`background:${p.accentColor}15;color:${p.accentColor}bb;border:1px solid ${p.accentColor}25;`}>
                      {tag}
                    </span>
                  ))}
                </div>

                <div class="flex gap-2">
                  <a href={p.demoUrl} class="btn-primary text-xs py-2 px-4 flex-1 justify-center">Demo</a>
                  <a href={p.codeUrl} class="btn-secondary text-xs py-2 px-4">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- See more -->
    <div class="reveal mt-12 text-center">
      <a
        href="https://www.linkedin.com/in/alessandro-sestili-59329b171/"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-secondary inline-flex"
      >
        Tutti i progetti su LinkedIn
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>
