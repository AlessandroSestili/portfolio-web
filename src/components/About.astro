---
---

<section id="about" class="relative py-32 px-6 overflow-hidden">
  <!-- Subtle orb -->
  <div
    class="orb absolute"
    style="width:400px;height:400px;top:50%;left:50%;transform:translate(-50%,-50%);
           background:radial-gradient(circle,rgba(6,182,212,0.06) 0%,transparent 65%);pointer-events:none;"
  ></div>

  <div class="max-w-6xl mx-auto">

    <!-- Section header -->
    <div class="reveal text-center mb-16">
      <span class="section-badge mb-4 inline-flex">// about_me</span>
      <h2 class="text-4xl sm:text-5xl font-black text-white mt-4">
        Chi sono
        <span class="text-gradient"> & cosa faccio</span>
      </h2>
    </div>

    <!-- Two-column layout -->
    <div class="grid lg:grid-cols-2 gap-12 items-center">

      <!-- LEFT — code block -->
      <div class="reveal-left">
        <div
          class="gradient-border rounded-2xl overflow-hidden"
          style="background:rgba(5,5,16,0.95);"
        >
          <!-- Editor chrome -->
          <div class="flex items-center gap-2 px-4 py-3 border-b border-white/5"
               style="background:rgba(255,255,255,0.02);">
            <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
            <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
            <span class="ml-3 font-mono text-xs text-white/30">developer.ts</span>
          </div>
          <!-- Code content -->
          <pre class="p-6 text-sm font-mono leading-relaxed overflow-x-auto">
<span class="text-violet-400">const</span> <span class="text-cyan-300">developer</span> <span class="text-white/60">=</span> <span class="text-amber-300">&#123;</span>
  <span class="text-sky-300">name</span><span class="text-white/60">:</span>        <span class="text-green-300">"Alessandro Sestili"</span><span class="text-white/60">,</span>
  <span class="text-sky-300">role</span><span class="text-white/60">:</span>        <span class="text-green-300">"Front End Developer"</span><span class="text-white/60">,</span>
  <span class="text-sky-300">experience</span><span class="text-white/60">:</span> <span class="text-green-300">"5+ anni"</span><span class="text-white/60">,</span>
  <span class="text-sky-300">location</span><span class="text-white/60">:</span>   <span class="text-green-300">"Italia 🇮🇹"</span><span class="text-white/60">,</span>
  <span class="text-sky-300">stack</span><span class="text-white/60">:</span>      <span class="text-amber-300">[</span>
    <span class="text-green-300">"React"</span><span class="text-white/60">,</span> <span class="text-green-300">"Angular"</span><span class="text-white/60">,</span>
    <span class="text-green-300">"TypeScript"</span><span class="text-white/60">,</span> <span class="text-green-300">"Vue.js"</span>
  <span class="text-amber-300">]</span><span class="text-white/60">,</span>
  <span class="text-sky-300">passion</span><span class="text-white/60">:</span>    <span class="text-amber-300">[</span>
    <span class="text-green-300">"Interfacce creative"</span><span class="text-white/60">,</span>
    <span class="text-green-300">"Performance optimization"</span><span class="text-white/60">,</span>
    <span class="text-green-300">"Clean architecture"</span>
  <span class="text-amber-300">]</span><span class="text-white/60">,</span>
  <span class="text-sky-300">available</span><span class="text-white/60">:</span>  <span class="text-violet-300">true</span>
<span class="text-amber-300">&#125;</span><span class="text-white/60">;</span></pre>
        </div>
      </div>

      <!-- RIGHT — bio & stats -->
      <div class="reveal-right space-y-7">
        <div class="space-y-4 text-white/60 leading-relaxed text-base sm:text-[0.975rem]">
          <p>
            Sono un <span class="text-white font-semibold">Front End Developer</span> con oltre 5 anni di
            esperienza nella creazione di esperienze digitali ad alte prestazioni. Il mio punto di forza
            è la capacità di tradurre design complessi in codice elegante ed efficiente.
          </p>
          <p>
            Lavoro principalmente con <span class="text-cyan-300 font-medium">React</span> e{' '}
            <span class="text-red-400 font-medium">Angular</span>, sfruttando al massimo il potere di{' '}
            <span class="text-blue-400 font-medium">TypeScript</span> per costruire applicazioni scalabili
            e facilmente mantenibili.
          </p>
          <p>
            Sono appassionato di UX, animazioni avanzate e component design — credo che la differenza
            tra un buon prodotto e un ottimo prodotto stia nei <span class="text-amber-400 font-medium">dettagli</span>.
          </p>
        </div>

        <!-- Stats grid -->
        <div class="grid grid-cols-2 gap-4">
          {[
            { value: '5+',  label: 'Anni di esperienza',  from: '#7C3AED', to: '#9333EA' },
            { value: '20+', label: 'Progetti completati', from: '#06B6D4', to: '#3B82F6' },
            { value: '4',   label: 'Framework principali',from: '#F59E0B', to: '#F97316' },
            { value: '∞',   label: 'Passion for code',    from: '#7C3AED', to: '#06B6D4' },
          ].map(s => (
            <div class="glass glass-hover rounded-xl p-4">
              <p
                class="text-3xl font-black mb-1"
                style={`background:linear-gradient(135deg,${s.from},${s.to});-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;`}
              >{s.value}</p>
              <p class="text-xs text-white/40 font-mono">{s.label}</p>
            </div>
          ))}
        </div>

        <!-- CTA row -->
        <div class="flex flex-wrap gap-3 pt-2">
          <a href="#contact" class="btn-primary">Parliamo insieme</a>
          <button onclick="openCvModal('/cv-classic.pdf', 'CV_Alessandro_Sestili_Classic.pdf')" class="btn-secondary">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            CV Classic
          </button>
          <button onclick="openCvModal('/cv-skills.pdf', 'CV_Alessandro_Sestili_Skills.pdf')" class="btn-secondary">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            CV Skills
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CV Modal -->
<div id="cv-modal" class="cv-modal-overlay" onclick="closeCvModal(event)">
  <div class="cv-modal-box">
    <div class="cv-modal-header">
      <span id="cv-modal-title" class="font-mono text-sm text-white/60"></span>
      <div class="flex items-center gap-3">
        <a id="cv-download-btn" href="#" download class="btn-secondary" style="padding:.4rem .9rem;font-size:.8rem;">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          Scarica
        </a>
        <button onclick="closeCvModal()" class="cv-close-btn" aria-label="Chiudi">✕</button>
      </div>
    </div>
    <iframe id="cv-iframe" src="" class="cv-iframe"></iframe>
  </div>
</div>

<style>
  .cv-modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0,0,0,.75);
    backdrop-filter: blur(6px);
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }
  .cv-modal-overlay.open {
    display: flex;
  }
  .cv-modal-box {
    background: rgba(8,8,20,0.97);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 18px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 860px;
    height: 90vh;
    box-shadow: 0 25px 80px rgba(0,0,0,.6);
  }
  .cv-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: .75rem 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,.07);
    background: rgba(255,255,255,.02);
    flex-shrink: 0;
  }
  .cv-close-btn {
    background: rgba(255,255,255,.07);
    border: 1px solid rgba(255,255,255,.1);
    color: #fff;
    border-radius: 8px;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: .85rem;
    transition: background .2s;
  }
  .cv-close-btn:hover { background: rgba(255,255,255,.14); }
  .cv-iframe {
    flex: 1;
    width: 100%;
    border: none;
  }
</style>

<script>
  function openCvModal(src, filename) {
    const modal = document.getElementById('cv-modal');
    document.getElementById('cv-iframe').src = src;
    document.getElementById('cv-modal-title').textContent = filename;
    document.getElementById('cv-download-btn').href = src;
    document.getElementById('cv-download-btn').download = filename;
    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeCvModal(e) {
    if (e && e.target !== document.getElementById('cv-modal')) return;
    _closeCvModal();
  }

  function _closeCvModal() {
    const modal = document.getElementById('cv-modal');
    modal.classList.remove('open');
    document.getElementById('cv-iframe').src = '';
    document.body.style.overflow = '';
  }

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') _closeCvModal();
  });

  // expose to inline onclick
  window.openCvModal = openCvModal;
  window.closeCvModal = closeCvModal;
</script>
