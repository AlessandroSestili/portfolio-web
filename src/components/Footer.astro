---
const currentYear = new Date().getFullYear();

const navLinks = [
  { href: '#about',    label: 'About'    },
  { href: '#stack',    label: 'Stack'    },
  { href: '#projects', label: 'Progetti' },
  { href: '#contact',  label: 'Contatti' },
];
---

<footer class="relative border-t border-white/5 py-12 px-6 overflow-hidden">
  <!-- Glow line at top -->
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-px pointer-events-none"
    style="background:linear-gradient(to right,transparent,rgba(124,58,237,0.5),rgba(6,182,212,0.5),transparent);"
  ></div>

  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">

      <!-- Left — brand -->
      <div class="flex flex-col items-center md:items-start gap-2">
        <div class="flex items-center gap-3">
          <div
            class="w-9 h-9 rounded-xl flex items-center justify-center text-xs font-bold font-mono text-white"
            style="background:linear-gradient(135deg,#7C3AED,#06B6D4);box-shadow:0 0 16px rgba(124,58,237,0.4);"
          >
            AS
          </div>
          <span class="font-semibold text-white text-sm">Alessandro Sestili</span>
        </div>
        <p class="text-xs text-white/30 font-mono">Front End Developer</p>
      </div>

      <!-- Center — nav links -->
      <nav class="flex flex-wrap justify-center gap-6">
        {navLinks.map(l => (
          <a
            href={l.href}
            class="text-xs font-medium text-white/40 hover:text-white transition-colors"
          >{l.label}</a>
        ))}
      </nav>

      <!-- Right — social row -->
      <div class="flex items-center gap-4">
        <a
          href="https://www.linkedin.com/in/alessandro-sestili-59329b171/"
          target="_blank"
          rel="noopener noreferrer"
          class="w-8 h-8 glass rounded-lg flex items-center justify-center text-white/40 hover:text-cyan-400 transition-all duration-200 hover:scale-110"
          aria-label="LinkedIn"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
          </svg>
        </a>
        <a
          href="mailto:sestilialessandro@gmail.com"
          class="w-8 h-8 glass rounded-lg flex items-center justify-center text-white/40 hover:text-violet-400 transition-all duration-200 hover:scale-110"
          aria-label="Email"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-6 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-xs text-white/20 font-mono">
        © {currentYear} Alessandro Sestili. Tutti i diritti riservati.
      </p>
      <p class="text-xs text-white/15 font-mono">
        Built with <span class="text-violet-400/60">Astro</span> + <span class="text-cyan-400/60">Tailwind CSS</span>
      </p>
    </div>
  </div>

  <!-- Back to top -->
  <button
    id="back-top"
    aria-label="Torna su"
    class="fixed bottom-6 right-6 w-11 h-11 rounded-xl flex items-center justify-center
           text-white/50 hover:text-white transition-all duration-300 opacity-0 translate-y-4 pointer-events-none
           z-40"
    style="background:rgba(124,58,237,0.2);border:1px solid rgba(124,58,237,0.3);backdrop-filter:blur(8px);"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/>
    </svg>
  </button>
</footer>

<script>
  const btn = document.getElementById('back-top');
  window.addEventListener('scroll', () => {
    if (!btn) return;
    if (window.scrollY > 400) {
      btn.style.opacity = '1';
      btn.style.transform = 'translateY(0)';
      btn.style.pointerEvents = 'auto';
    } else {
      btn.style.opacity = '0';
      btn.style.transform = 'translateY(16px)';
      btn.style.pointerEvents = 'none';
    }
  });
  btn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
</script>
