---
type Tech = {
  icon?: string;
  svg?: string;
  name: string;
  color: string;
  glow: string;
};

type Category = {
  title: string;
  emoji: string;
  techs: Tech[];
};

const categories: Category[] = [
  {
    title: 'Framework',
    emoji: '⚡',
    techs: [
      { icon: 'devicon-react-original',     name: 'React',      color: '#61DAFB', glow: 'rgba(97,218,251,0.25)'  },
      { icon: 'devicon-angularjs-plain',    name: 'Angular',    color: '#DD0031', glow: 'rgba(221,0,49,0.25)'    },
      { icon: 'devicon-vuejs-plain',        name: 'Vue.js',     color: '#4FC08D', glow: 'rgba(79,192,141,0.25)'  },
      { svg: '<svg viewBox="0 0 24 24" fill="white" class="w-10 h-10 sm:w-12 sm:h-12"><path d="M11.572 0c-.176 0-.31.001-.358.007a19.76 19.76 0 0 1-.364.033C7.443.346 4.25 2.185 2.228 5.012a11.875 11.875 0 0 0-2.119 5.243c-.096.659-.108.854-.108 1.747s.012 1.089.108 1.748c.652 4.506 3.86 8.292 8.209 9.695.779.25 1.6.422 2.534.525.363.04 1.935.04 2.299 0 1.611-.178 2.977-.577 4.323-1.264.207-.106.247-.134.219-.158-.02-.013-.9-1.193-1.955-2.62l-1.919-2.592-2.404-3.558a338.739 338.739 0 0 0-2.422-3.556c-.009-.002-.018 1.579-.023 3.51-.007 3.38-.01 3.515-.052 3.595a.426.426 0 0 1-.206.214c-.075.037-.14.044-.495.044H7.81l-.108-.068a.438.438 0 0 1-.157-.171l-.05-.106.006-4.703.007-4.705.072-.092a.645.645 0 0 1 .174-.143c.096-.047.134-.051.54-.051.478 0 .558.018.682.154.035.038 1.337 1.999 2.895 4.361a10760.433 10760.433 0 0 0 4.735 7.17l1.9 2.879.096-.063a12.317 12.317 0 0 0 2.466-2.163 11.944 11.944 0 0 0 2.824-6.134c.096-.66.108-.854.108-1.748 0-.893-.012-1.088-.108-1.747-.652-4.506-3.859-8.292-8.208-9.695a12.597 12.597 0 0 0-2.499-.523A33.119 33.119 0 0 0 11.573 0zm4.069 7.217c.347 0 .408.005.486.047a.473.473 0 0 1 .237.277c.018.06.023 1.365.018 4.304l-.006 4.218-.744-1.14-.746-1.14v-3.066c0-1.982.01-3.097.023-3.15a.478.478 0 0 1 .233-.296c.096-.05.13-.054.5-.054z"/></svg>', name: 'Next.js', color: '#FFFFFF', glow: 'rgba(255,255,255,0.15)' },
    ],
  },
  {
    title: 'Linguaggi',
    emoji: '🧠',
    techs: [
      { icon: 'devicon-typescript-plain',   name: 'TypeScript', color: '#3178C6', glow: 'rgba(49,120,198,0.3)'  },
      { icon: 'devicon-javascript-plain',   name: 'JavaScript', color: '#F7DF1E', glow: 'rgba(247,223,30,0.25)' },
      { icon: 'devicon-html5-plain',        name: 'HTML5',      color: '#E34F26', glow: 'rgba(227,79,38,0.25)'  },
      { icon: 'devicon-css3-plain',         name: 'CSS3',       color: '#1572B6', glow: 'rgba(21,114,182,0.3)'  },
    ],
  },
  {
    title: 'Tools & Ecosistema',
    emoji: '🛠',
    techs: [
      { icon: 'devicon-tailwindcss-plain',  name: 'Tailwind',   color: '#06B6D4', glow: 'rgba(6,182,212,0.3)'   },
      { icon: 'devicon-nodejs-plain',       name: 'Node.js',    color: '#339933', glow: 'rgba(51,153,51,0.25)'  },
      { icon: 'devicon-git-plain',          name: 'Git',        color: '#F05032', glow: 'rgba(240,80,50,0.25)'  },
      { icon: 'devicon-webpack-plain',      name: 'Webpack',    color: '#8DD6F9', glow: 'rgba(141,214,249,0.2)' },
    ],
  },
];
---

<section id="stack" class="relative py-32 px-6 overflow-hidden">
  <!-- Background orbs -->
  <div
    class="orb absolute animate-float-slow"
    style="width:500px;height:500px;top:-50px;right:-100px;
           background:radial-gradient(circle,rgba(124,58,237,0.07) 0%,transparent 65%);pointer-events:none;"
  ></div>

  <!-- Separator line -->
  <div class="max-w-6xl mx-auto mb-16">
    <div class="h-px w-full" style="background:linear-gradient(to right,transparent,rgba(124,58,237,0.4),transparent);"></div>
  </div>

  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="reveal text-center mb-16">
      <span class="section-badge mb-4 inline-flex">// tech_stack</span>
      <h2 class="text-4xl sm:text-5xl font-black text-white mt-4">
        Le mie <span class="text-gradient">tecnologie</span>
      </h2>
      <p class="text-white/40 mt-4 max-w-xl mx-auto text-sm">
        Il mio arsenale quotidiano — strumenti che conosco a fondo e con cui costruisco prodotti di qualità.
      </p>
    </div>

    <!-- Categories -->
    <div class="space-y-14">
      {categories.map((cat, ci) => (
        <div class={`reveal reveal-delay-${ci + 1}`}>
          <!-- Category label -->
          <div class="flex items-center gap-3 mb-6">
            <span class="text-xl">{cat.emoji}</span>
            <h3 class="font-mono text-sm font-bold text-white/50 tracking-widest uppercase">
              {cat.title}
            </h3>
            <div class="flex-1 h-px" style="background:linear-gradient(to right,rgba(255,255,255,0.08),transparent);"></div>
          </div>

          <!-- Tech cards grid -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            {cat.techs.map((tech, ti) => (
              <div
                class={`glass glass-hover card-tilt rounded-2xl p-5 flex flex-col items-center gap-3
                        cursor-default select-none reveal reveal-delay-${ti + 1}`}
                style={`--glow:${tech.glow};`}
              >
                {tech.svg
                  ? <Fragment set:html={tech.svg} style={`filter:drop-shadow(0 0 12px ${tech.glow});display:block;`} />
                  : <i class={`${tech.icon} colored text-4xl sm:text-5xl transition-all duration-300`} style={`filter:drop-shadow(0 0 12px ${tech.glow});`}></i>
                }
                <span class="font-mono text-xs font-semibold text-white/70 tracking-wide">
                  {tech.name}
                </span>

                <!-- Skill bar -->
                <div class="w-full h-0.5 rounded-full bg-white/5 overflow-hidden">
                  <div
                    class="h-full rounded-full"
                    style={`width:${90 - ti * 5}%;background:linear-gradient(to right,${tech.color}80,${tech.color});`}
                  ></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom tag -->
    <div class="reveal mt-16 text-center">
      <p class="font-mono text-xs text-white/25 tracking-wider">
        + Astro, Vite, Docker, Figma, REST APIs, GraphQL, Jest, Cypress…
      </p>
    </div>
  </div>
</section>

<style>
  .glass-hover:hover i {
    transform: scale(1.15) translateZ(20px);
  }
</style>
