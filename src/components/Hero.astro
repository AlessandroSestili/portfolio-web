---
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden"
>
  <!-- ── Background layer ── -->
  <div class="absolute inset-0 pointer-events-none">
    <!-- Dot grid -->
    <div
      class="absolute inset-0 opacity-40"
      style="background-image:radial-gradient(circle at 1px 1px,rgba(255,255,255,0.05) 1px,transparent 0);background-size:44px 44px;"
    ></div>

    <!-- Floating orbs -->
    <div
      class="orb animate-float-slow"
      style="width:600px;height:600px;top:-100px;left:-200px;background:radial-gradient(circle,rgba(124,58,237,0.25) 0%,transparent 70%);"
    ></div>
    <div
      class="orb animate-float-med"
      style="width:500px;height:500px;bottom:-50px;right:-150px;background:radial-gradient(circle,rgba(6,182,212,0.2) 0%,transparent 70%);"
    ></div>
    <div
      class="orb animate-float-fast"
      style="width:300px;height:300px;top:40%;left:60%;background:radial-gradient(circle,rgba(245,158,11,0.12) 0%,transparent 70%);"
    ></div>
  </div>

  <!-- ── Content ── -->
  <div class="relative z-10 text-center px-6 max-w-5xl mx-auto pt-24">

    <!-- Tag line -->
    <div class="reveal mb-6 flex justify-center">
      <span class="section-badge">
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
        Disponibile per nuovi progetti
      </span>
    </div>

    <!-- Name -->
    <div class="reveal reveal-delay-1 mb-4">
      <h1 class="text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-black leading-none tracking-tight">
        <span
          class="glitch-wrapper text-gradient"
          data-text="Alessandro"
        >Alessandro</span>
        <br />
        <span class="text-white">Sestili</span>
      </h1>
    </div>

    <!-- Role typewriter -->
    <div class="reveal reveal-delay-2 mb-6 h-8 sm:h-10 flex items-center justify-center">
      <p class="font-mono text-xl sm:text-2xl text-violet-300 flex items-center gap-1">
        <span id="typewriter-text"></span>
        <span
          class="inline-block w-0.5 h-6 sm:h-7 bg-cyan-400 align-middle animate-pulse"
        ></span>
      </p>
    </div>

    <!-- Tagline -->
    <div class="reveal reveal-delay-3 mb-10">
      <p class="text-base sm:text-lg md:text-xl text-white/50 max-w-2xl mx-auto leading-relaxed">
        Costruisco interfacce digitali che{' '}
        <span class="text-amber-400 font-semibold">lasciano il segno</span>
        {' '}— dove codice pulito incontra visioni creative.
      </p>
    </div>

    <!-- CTAs -->
    <div class="reveal reveal-delay-4 flex flex-wrap items-center justify-center gap-4 mb-12">
      <a href="#projects" class="btn-primary">
        Vedi i Progetti
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </a>
      <a href="#contact" class="btn-secondary">
        Contattami
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </a>
    </div>

    <!-- Social links -->
    <div class="reveal reveal-delay-5 flex items-center justify-center gap-6 mb-16">
      <!-- LinkedIn -->
      <a
        href="https://www.linkedin.com/in/alessandro-sestili-59329b171/"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-white/40 hover:text-cyan-400 transition-all duration-200 hover:scale-110 text-sm font-medium"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
        </svg>
        LinkedIn
      </a>

      <span class="w-px h-4 bg-white/10"></span>

      <!-- Email -->
      <a
        href="mailto:sestilialessandro@gmail.com"
        class="flex items-center gap-2 text-white/40 hover:text-violet-400 transition-all duration-200 hover:scale-110 text-sm font-medium"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        Email
      </a>
    </div>

    <!-- Stats strip -->
    <div class="reveal reveal-delay-6">
      <div class="glass rounded-2xl px-8 py-5 inline-flex flex-wrap items-center justify-center gap-8 sm:gap-12">
        <div class="text-center">
          <p class="text-2xl font-black text-gradient">5+</p>
          <p class="text-xs text-white/40 mt-0.5 font-mono">Anni di esperienza</p>
        </div>
        <div class="w-px h-8 bg-white/10"></div>
        <div class="text-center">
          <p class="text-2xl font-black text-gradient-amber">20+</p>
          <p class="text-xs text-white/40 mt-0.5 font-mono">Progetti completati</p>
        </div>
        <div class="w-px h-8 bg-white/10"></div>
        <div class="text-center">
          <p class="text-2xl font-black" style="background:linear-gradient(135deg,#7C3AED,#F59E0B);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">4</p>
          <p class="text-xs text-white/40 mt-0.5 font-mono">Framework padroneggiati</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/20">
    <span class="font-mono text-[10px] tracking-widest uppercase">scroll</span>
    <div class="relative w-5 h-8 rounded-full border border-white/15 flex justify-center pt-1.5">
      <div class="w-1 h-2 rounded-full bg-violet-400 animate-scroll-down"></div>
    </div>
  </div>
</section>

<script>
  const roles = [
    'Front End Developer',
    'React Specialist',
    'UI/UX Craftsman',
    'TypeScript Engineer',
    'Angular Expert',
  ];

  let roleIndex = 0;
  let charIndex  = 0;
  let isDeleting = false;
  const target   = document.getElementById('typewriter-text');

  function tick() {
    if (!target) return;
    const current = roles[roleIndex];

    if (isDeleting) {
      charIndex--;
      target.textContent = current.substring(0, charIndex);
      if (charIndex === 0) {
        isDeleting = false;
        roleIndex  = (roleIndex + 1) % roles.length;
        setTimeout(tick, 400);
        return;
      }
      setTimeout(tick, 40);
    } else {
      charIndex++;
      target.textContent = current.substring(0, charIndex);
      if (charIndex === current.length) {
        isDeleting = true;
        setTimeout(tick, 2200);
        return;
      }
      setTimeout(tick, 90);
    }
  }

  setTimeout(tick, 800);
</script>
